# CoinGecko API key — put the real value in .env.local (never commit secrets)
# Demo keys (CG-…): default below is enough
# Pro keys: also set COINGECKO_PRO=true
COINGECKO_API_KEY=
# COINGECKO_PRO=true

# Netlify production: set the same key in the dashboard or:
#   npx netlify-cli env:set COINGECKO_API_KEY "CG-…"
# Public site URL for OG/canonical (match Netlify domain)
# NEXT_PUBLIC_SITE_URL=https://kryptotrac.netlify.app
